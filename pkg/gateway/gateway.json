  "rateLimit": {
    "moduleName": "ratelimit",
    "enabled": false,
    "strategy": "token-bucket",
    "defaultScope": "global",
    "globalLimit": {
      "requestsPerSecond": 100,
      "burstSize": 200,
      "windowSize": 60000000000,
      "blockDuration": 60000000000
    },
    "routes": [],
    "ipRules": [],
    "userRules": [],
    "storage": {
      "type": "memory",
      "keyPrefix": "rate_limit:",
      "cleanInterval": 300000000000,
      "redis": null
    },
    "customRuleLoader": "",
    "enableDynamicRule": false,
    "emailAlertConfig": {
      "enabled": false,
      "to": [
        "admin@example.com"
      ],
      "cc": [],
      "appName": "RateLimit System",
      "environment": "production",
      "subjectAlert": "⚠️ 风控预警 - {{.AppName}}",
      "subjectBlock": "🚫 风控封禁 - {{.AppName}}",
      "templateAlert": "\n\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh-CN\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\n    \u003ctitle\u003e风控预警通知\u003c/title\u003e\n    \u003cstyle\u003e\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: #f5f5f5;\n        }\n        .email-container {\n            max-width: 600px;\n            margin: 20px auto;\n            background-color: #ffffff;\n            border-radius: 8px;\n            overflow: hidden;\n            box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n        }\n        .email-header {\n            background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);\n            color: #ffffff;\n            padding: 30px;\n            text-align: center;\n        }\n        .email-header h1 {\n            margin: 0;\n            font-size: 28px;\n            font-weight: 600;\n        }\n        .email-header .icon {\n            font-size: 48px;\n            margin-bottom: 10px;\n        }\n        .email-body {\n            padding: 30px;\n        }\n        .alert-info {\n            background-color: #fff3cd;\n            border-left: 4px solid #ffc107;\n            padding: 15px;\n            margin: 20px 0;\n            border-radius: 4px;\n        }\n        .alert-info h2 {\n            margin: 0 0 10px 0;\n            color: #856404;\n            font-size: 18px;\n        }\n        .info-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin: 20px 0;\n        }\n        .info-table th,\n        .info-table td {\n            padding: 12px;\n            text-align: left;\n            border-bottom: 1px solid #e0e0e0;\n        }\n        .info-table th {\n            background-color: #f8f9fa;\n            font-weight: 600;\n            color: #333;\n            width: 35%;\n        }\n        .info-table td {\n            color: #666;\n        }\n        .metric-card {\n            display: inline-block;\n            width: 48%;\n            margin: 1%;\n            padding: 15px;\n            background-color: #f8f9fa;\n            border-radius: 6px;\n            text-align: center;\n            box-sizing: border-box;\n        }\n        .metric-card .label {\n            font-size: 12px;\n            color: #666;\n            margin-bottom: 5px;\n        }\n        .metric-card .value {\n            font-size: 24px;\n            font-weight: bold;\n            color: #ffc107;\n        }\n        .threshold-bar {\n            width: 100%;\n            height: 30px;\n            background-color: #e0e0e0;\n            border-radius: 15px;\n            overflow: hidden;\n            margin: 20px 0;\n        }\n        .threshold-fill {\n            height: 100%;\n            background: linear-gradient(90deg, #ffc107 0%, #ff9800 100%);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 12px;\n        }\n        .action-section {\n            background-color: #e8f4fd;\n            border-left: 4px solid #2196f3;\n            padding: 15px;\n            margin: 20px 0;\n            border-radius: 4px;\n        }\n        .action-section h3 {\n            margin: 0 0 10px 0;\n            color: #1976d2;\n            font-size: 16px;\n        }\n        .action-section ul {\n            margin: 0;\n            padding-left: 20px;\n        }\n        .action-section li {\n            margin: 8px 0;\n            color: #666;\n        }\n        .email-footer {\n            background-color: #f8f9fa;\n            padding: 20px;\n            text-align: center;\n            color: #999;\n            font-size: 12px;\n        }\n        .email-footer a {\n            color: #2196f3;\n            text-decoration: none;\n        }\n        @media only screen and (max-width: 600px) {\n            .metric-card {\n                width: 100%;\n                margin: 10px 0;\n            }\n        }\n    \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    \u003cdiv class=\"email-container\"\u003e\n        \u003c!-- 邮件头部 --\u003e\n        \u003cdiv class=\"email-header\"\u003e\n            \u003cdiv class=\"icon\"\u003e⚠️\u003c/div\u003e\n            \u003ch1\u003e风控预警通知\u003c/h1\u003e\n            \u003cp style=\"margin: 10px 0 0 0; opacity: 0.9;\"\u003e{{.AppName}} - {{.Environment}}\u003c/p\u003e\n        \u003c/div\u003e\n\n        \u003c!-- 邮件正文 --\u003e\n        \u003cdiv class=\"email-body\"\u003e\n            \u003c!-- 预警信息 --\u003e\n            \u003cdiv class=\"alert-info\"\u003e\n                \u003ch2\u003e⚠️ 检测到异常行为\u003c/h2\u003e\n                \u003cp style=\"margin: 5px 0 0 0; color: #856404;\"\u003e\n                    用户 \u003cstrong\u003e{{.UserID}}\u003c/strong\u003e ({{.UserType}}) 的消息发送频率已达到预警阈值\n                \u003c/p\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 详细信息表格 --\u003e\n            \u003ctable class=\"info-table\"\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e🆔 用户ID\u003c/th\u003e\n                    \u003ctd\u003e{{.UserID}}\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e👤 用户类型\u003c/th\u003e\n                    \u003ctd\u003e{{.UserType}}\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e📊 分钟计数\u003c/th\u003e\n                    \u003ctd\u003e\u003cstrong\u003e{{.MinuteCount}}\u003c/strong\u003e 条/分钟\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e📊 小时计数\u003c/th\u003e\n                    \u003ctd\u003e\u003cstrong\u003e{{.HourCount}}\u003c/strong\u003e 条/小时\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e🎯 预警阈值\u003c/th\u003e\n                    \u003ctd\u003e{{.AlertThreshold}} 条/分钟\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e🚫 封禁阈值\u003c/th\u003e\n                    \u003ctd\u003e{{.BlockThreshold}} 条/分钟\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e🕐 触发时间\u003c/th\u003e\n                    \u003ctd\u003e{{.Timestamp}}\u003c/td\u003e\n                \u003c/tr\u003e\n            \u003c/table\u003e\n\n            \u003c!-- 统计指标卡片 --\u003e\n            \u003cdiv style=\"margin: 20px 0;\"\u003e\n                \u003cdiv class=\"metric-card\"\u003e\n                    \u003cdiv class=\"label\"\u003e分钟消息数\u003c/div\u003e\n                    \u003cdiv class=\"value\"\u003e{{.MinuteCount}}\u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class=\"metric-card\"\u003e\n                    \u003cdiv class=\"label\"\u003e小时消息数\u003c/div\u003e\n                    \u003cdiv class=\"value\"\u003e{{.HourCount}}\u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 阈值进度条 --\u003e\n            \u003cdiv style=\"margin: 20px 0;\"\u003e\n                \u003cp style=\"margin: 0 0 8px 0; font-size: 14px; color: #666;\"\u003e预警阈值进度\u003c/p\u003e\n                \u003cdiv class=\"threshold-bar\"\u003e\n                    \u003cdiv class=\"threshold-fill\" style=\"width: {{.AlertPercentage}}%;\"\u003e\n                        {{.AlertPercentage}}%\n                    \u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 建议操作 --\u003e\n            \u003cdiv class=\"action-section\"\u003e\n                \u003ch3\u003e📋 建议处理措施\u003c/h3\u003e\n                \u003cul\u003e\n                    \u003cli\u003e立即检查用户 {{.UserID}} 的行为日志\u003c/li\u003e\n                    \u003cli\u003e确认是否为正常业务操作还是恶意行为\u003c/li\u003e\n                    \u003cli\u003e如确认异常，可手动封禁该用户\u003c/li\u003e\n                    \u003cli\u003e监控后续行为，防止达到自动封禁阈值\u003c/li\u003e\n                    \u003cli\u003e如有必要，调整风控策略参数\u003c/li\u003e\n                \u003c/ul\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 系统信息 --\u003e\n            \u003cdiv style=\"margin-top: 30px; padding-top: 20px; border-top: 1px solid #e0e0e0;\"\u003e\n                \u003cp style=\"margin: 0; font-size: 12px; color: #999;\"\u003e\n                    📌 此邮件由 {{.AppName}} 风控系统自动发送\u003cbr\u003e\n                    🏢 环境: {{.Environment}}\u003cbr\u003e\n                    🕐 发送时间: {{.Timestamp}}\n                \u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003c!-- 邮件尾部 --\u003e\n        \u003cdiv class=\"email-footer\"\u003e\n            \u003cp\u003e© 2025 {{.AppName}}. All rights reserved.\u003c/p\u003e\n            \u003cp\u003e\n                如有疑问，请联系 \u003ca href=\"mailto:{{.SupportEmail}}\"\u003e技术支持\u003c/a\u003e\n            \u003c/p\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n",
      "templateBlock": "\n\u003c!DOCTYPE html\u003e\n\u003chtml lang=\"zh-CN\"\u003e\n\u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\n    \u003ctitle\u003e风控封禁通知\u003c/title\u003e\n    \u003cstyle\u003e\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: #f5f5f5;\n        }\n        .email-container {\n            max-width: 600px;\n            margin: 20px auto;\n            background-color: #ffffff;\n            border-radius: 8px;\n            overflow: hidden;\n            box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n        }\n        .email-header {\n            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);\n            color: #ffffff;\n            padding: 30px;\n            text-align: center;\n        }\n        .email-header h1 {\n            margin: 0;\n            font-size: 28px;\n            font-weight: 600;\n        }\n        .email-header .icon {\n            font-size: 48px;\n            margin-bottom: 10px;\n        }\n        .email-body {\n            padding: 30px;\n        }\n        .alert-danger {\n            background-color: #f8d7da;\n            border-left: 4px solid #dc3545;\n            padding: 15px;\n            margin: 20px 0;\n            border-radius: 4px;\n        }\n        .alert-danger h2 {\n            margin: 0 0 10px 0;\n            color: #721c24;\n            font-size: 18px;\n        }\n        .info-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin: 20px 0;\n        }\n        .info-table th,\n        .info-table td {\n            padding: 12px;\n            text-align: left;\n            border-bottom: 1px solid #e0e0e0;\n        }\n        .info-table th {\n            background-color: #f8f9fa;\n            font-weight: 600;\n            color: #333;\n            width: 35%;\n        }\n        .info-table td {\n            color: #666;\n        }\n        .metric-card {\n            display: inline-block;\n            width: 48%;\n            margin: 1%;\n            padding: 15px;\n            background-color: #f8f9fa;\n            border-radius: 6px;\n            text-align: center;\n            box-sizing: border-box;\n        }\n        .metric-card .label {\n            font-size: 12px;\n            color: #666;\n            margin-bottom: 5px;\n        }\n        .metric-card .value {\n            font-size: 24px;\n            font-weight: bold;\n            color: #dc3545;\n        }\n        .threshold-bar {\n            width: 100%;\n            height: 30px;\n            background-color: #e0e0e0;\n            border-radius: 15px;\n            overflow: hidden;\n            margin: 20px 0;\n        }\n        .threshold-fill {\n            height: 100%;\n            background: linear-gradient(90deg, #dc3545 0%, #c82333 100%);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 12px;\n        }\n        .action-section {\n            background-color: #fff3cd;\n            border-left: 4px solid #ffc107;\n            padding: 15px;\n            margin: 20px 0;\n            border-radius: 4px;\n        }\n        .action-section h3 {\n            margin: 0 0 10px 0;\n            color: #856404;\n            font-size: 16px;\n        }\n        .action-section ul {\n            margin: 0;\n            padding-left: 20px;\n        }\n        .action-section li {\n            margin: 8px 0;\n            color: #666;\n        }\n        .critical-warning {\n            background-color: #fff3cd;\n            border: 2px solid #ffc107;\n            padding: 20px;\n            margin: 20px 0;\n            border-radius: 6px;\n            text-align: center;\n        }\n        .critical-warning .warning-icon {\n            font-size: 48px;\n            margin-bottom: 10px;\n        }\n        .critical-warning h3 {\n            margin: 0 0 10px 0;\n            color: #856404;\n            font-size: 20px;\n        }\n        .email-footer {\n            background-color: #f8f9fa;\n            padding: 20px;\n            text-align: center;\n            color: #999;\n            font-size: 12px;\n        }\n        .email-footer a {\n            color: #2196f3;\n            text-decoration: none;\n        }\n        @media only screen and (max-width: 600px) {\n            .metric-card {\n                width: 100%;\n                margin: 10px 0;\n            }\n        }\n    \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    \u003cdiv class=\"email-container\"\u003e\n        \u003c!-- 邮件头部 --\u003e\n        \u003cdiv class=\"email-header\"\u003e\n            \u003cdiv class=\"icon\"\u003e🚫\u003c/div\u003e\n            \u003ch1\u003e风控封禁通知\u003c/h1\u003e\n            \u003cp style=\"margin: 10px 0 0 0; opacity: 0.9;\"\u003e{{.AppName}} - {{.Environment}}\u003c/p\u003e\n        \u003c/div\u003e\n\n        \u003c!-- 邮件正文 --\u003e\n        \u003cdiv class=\"email-body\"\u003e\n            \u003c!-- 严重警告 --\u003e\n            \u003cdiv class=\"critical-warning\"\u003e\n                \u003cdiv class=\"warning-icon\"\u003e⚠️\u003c/div\u003e\n                \u003ch3\u003e用户已被自动封禁\u003c/h3\u003e\n                \u003cp style=\"margin: 10px 0 0 0; color: #856404; font-weight: 600;\"\u003e\n                    检测到严重的频率滥用行为，系统已自动执行封禁操作\n                \u003c/p\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 封禁信息 --\u003e\n            \u003cdiv class=\"alert-danger\"\u003e\n                \u003ch2\u003e🚫 封禁详情\u003c/h2\u003e\n                \u003cp style=\"margin: 5px 0 0 0; color: #721c24;\"\u003e\n                    用户 \u003cstrong\u003e{{.UserID}}\u003c/strong\u003e ({{.UserType}}) 因超过最大消息频率阈值被封禁\n                \u003c/p\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 详细信息表格 --\u003e\n            \u003ctable class=\"info-table\"\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e🆔 用户ID\u003c/th\u003e\n                    \u003ctd\u003e{{.UserID}}\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e👤 用户类型\u003c/th\u003e\n                    \u003ctd\u003e{{.UserType}}\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e📊 分钟计数\u003c/th\u003e\n                    \u003ctd\u003e\u003cstrong style=\"color: #dc3545;\"\u003e{{.MinuteCount}}\u003c/strong\u003e 条/分钟\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e📊 小时计数\u003c/th\u003e\n                    \u003ctd\u003e\u003cstrong style=\"color: #dc3545;\"\u003e{{.HourCount}}\u003c/strong\u003e 条/小时\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e🚫 封禁阈值\u003c/th\u003e\n                    \u003ctd\u003e{{.BlockThreshold}} 条/分钟\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e📈 超出比例\u003c/th\u003e\n                    \u003ctd\u003e\u003cstrong style=\"color: #dc3545;\"\u003e{{.ExceedPercentage}}%\u003c/strong\u003e\u003c/td\u003e\n                \u003c/tr\u003e\n                \u003ctr\u003e\n                    \u003cth\u003e🕐 封禁时间\u003c/th\u003e\n                    \u003ctd\u003e{{.Timestamp}}\u003c/td\u003e\n                \u003c/tr\u003e\n            \u003c/table\u003e\n\n            \u003c!-- 统计指标卡片 --\u003e\n            \u003cdiv style=\"margin: 20px 0;\"\u003e\n                \u003cdiv class=\"metric-card\"\u003e\n                    \u003cdiv class=\"label\"\u003e分钟消息数\u003c/div\u003e\n                    \u003cdiv class=\"value\"\u003e{{.MinuteCount}}\u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class=\"metric-card\"\u003e\n                    \u003cdiv class=\"label\"\u003e小时消息数\u003c/div\u003e\n                    \u003cdiv class=\"value\"\u003e{{.HourCount}}\u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 阈值进度条 --\u003e\n            \u003cdiv style=\"margin: 20px 0;\"\u003e\n                \u003cp style=\"margin: 0 0 8px 0; font-size: 14px; color: #666;\"\u003e封禁阈值进度（已超限）\u003c/p\u003e\n                \u003cdiv class=\"threshold-bar\"\u003e\n                    \u003cdiv class=\"threshold-fill\" style=\"width: 100%;\"\u003e\n                        超限 {{.ExceedPercentage}}%\n                    \u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 紧急处理建议 --\u003e\n            \u003cdiv class=\"action-section\"\u003e\n                \u003ch3\u003e🔥 紧急处理措施\u003c/h3\u003e\n                \u003cul\u003e\n                    \u003cli\u003e\u003cstrong\u003e立即调查\u003c/strong\u003e用户 {{.UserID}} 的完整行为日志\u003c/li\u003e\n                    \u003cli\u003e\u003cstrong\u003e确认来源\u003c/strong\u003e：是机器人攻击还是误封正常用户\u003c/li\u003e\n                    \u003cli\u003e\u003cstrong\u003e评估影响\u003c/strong\u003e：检查是否还有其他受影响的用户\u003c/li\u003e\n                    \u003cli\u003e\u003cstrong\u003e通知相关方\u003c/strong\u003e：如确认为攻击，通知安全团队\u003c/li\u003e\n                    \u003cli\u003e\u003cstrong\u003e手动解封\u003c/strong\u003e：如确认误封，及时手动解除封禁\u003c/li\u003e\n                    \u003cli\u003e\u003cstrong\u003e调整策略\u003c/strong\u003e：根据实际情况优化风控阈值\u003c/li\u003e\n                \u003c/ul\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 后续行动 --\u003e\n            \u003cdiv style=\"background-color: #e8f4fd; border-left: 4px solid #2196f3; padding: 15px; margin: 20px 0; border-radius: 4px;\"\u003e\n                \u003ch3 style=\"margin: 0 0 10px 0; color: #1976d2; font-size: 16px;\"\u003e📋 后续跟进\u003c/h3\u003e\n                \u003cp style=\"margin: 0; color: #666; line-height: 1.6;\"\u003e\n                    1. 在系统中记录此次封禁事件\u003cbr\u003e\n                    2. 建立用户行为分析报告\u003cbr\u003e\n                    3. 评估是否需要升级风控策略\u003cbr\u003e\n                    4. 定期审查封禁用户列表\n                \u003c/p\u003e\n            \u003c/div\u003e\n\n            \u003c!-- 系统信息 --\u003e\n            \u003cdiv style=\"margin-top: 30px; padding-top: 20px; border-top: 1px solid #e0e0e0;\"\u003e\n                \u003cp style=\"margin: 0; font-size: 12px; color: #999;\"\u003e\n                    📌 此邮件由 {{.AppName}} 风控系统自动发送\u003cbr\u003e\n                    🏢 环境: {{.Environment}}\u003cbr\u003e\n                    🕐 封禁时间: {{.Timestamp}}\u003cbr\u003e\n                    ⚠️ 优先级: \u003cstrong style=\"color: #dc3545;\"\u003e紧急\u003c/strong\u003e\n                \u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003c!-- 邮件尾部 --\u003e\n        \u003cdiv class=\"email-footer\"\u003e\n            \u003cp\u003e© 2025 {{.AppName}}. All rights reserved.\u003c/p\u003e\n            \u003cp\u003e\n                紧急联系: \u003ca href=\"mailto:{{.SecurityEmail}}\"\u003e安全团队\u003c/a\u003e | \n                技术支持: \u003ca href=\"mailto:{{.SupportEmail}}\"\u003e技术支持\u003c/a\u003e\n            \u003c/p\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n",
      "cooldownMinutes": 5,
      "maxAlertsPerHour": 20,
      "supportEmail": "support@example.com",
      "securityEmail": "security@example.com"
    }
  },
